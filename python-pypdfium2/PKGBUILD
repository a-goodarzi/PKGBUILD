# Maintainer: Goodarz <1831847+a-goodarzi@users.noreply.github.com>

pkgname=python-pypdfium2
pkgver=5.7.0
pkgrel=1
pkgdesc='An ABI-level Python 3 binding to PDFium (unofficial AUR package)'
arch=('x86_64')
url='https://github.com/pypdfium2-team/pypdfium2'
license=('Apache-2.0' 'BSD-3-Clause')
depends=('python')
makedepends=(
  'git'
  'python-build'
  'python-installer'
  'python-packaging'
  'python-setuptools'
  'python-wheel'
)
optdepends=(
  'python-pillow: support PIL image objects for raster graphics'
  'python-numpy: support numpy arrays for raster graphics'
  "python-opencv: save with pypdfium2's numpy adapter in the rendering CLI"
  'python-tabulate: prettier CLI table output'
)
_name=${pkgname#python-}
_ctypesgencommit='85eb5bd446f63a2a0373831dbf4dedc854d5bd40'
_pdfiumver=7825
source=(
  "https://files.pythonhosted.org/packages/source/${_name::1}/${_name}/${_name}-${pkgver}.tar.gz"
  "ctypesgen::git+https://github.com/pypdfium2-team/ctypesgen#commit=${_ctypesgencommit}"
)
source_x86_64=(
  "pdfium-linux-x64-${_pdfiumver}.tgz::https://github.com/bblanchon/pdfium-binaries/releases/download/chromium%2F${_pdfiumver}/pdfium-linux-x64.tgz"
)
noextract=("pdfium-linux-x64-${_pdfiumver}.tgz")
sha256sums=(
  '049397c647e50f83115ee951c49394dab9e9ba52ebdd5a11ab1109390eb3d34e'
  'SKIP'
)
sha256sums_x86_64=(
  'ae0e276bcdf276dca2746adb4780f79949620e5c655973ca252a3994bc516a13'
)

prepare() {
  cd "${_name}-${pkgver}"
  sed -i '/ctypesgen @ git+https:\/\/github.com\/pypdfium2-team\/ctypesgen/d' pyproject.toml
  mkdir -p data/linux_x64/BUILD_LICENSES data/bindings/headers

  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" lib/libpdfium.so > data/linux_x64/libpdfium.so
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" LICENSE > data/linux_x64/BUILD_LICENSES/pdfium-binaries.txt
  bsdtar -tf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" | while read -r _file; do
    case "${_file}" in
      licenses/)
        ;;
      licenses/*)
        bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" "${_file}" > "data/linux_x64/BUILD_LICENSES/${_file##*/}"
        ;;
    esac
  done
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_annot.h > data/bindings/headers/fpdf_annot.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_attachment.h > data/bindings/headers/fpdf_attachment.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_catalog.h > data/bindings/headers/fpdf_catalog.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_dataavail.h > data/bindings/headers/fpdf_dataavail.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_doc.h > data/bindings/headers/fpdf_doc.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_edit.h > data/bindings/headers/fpdf_edit.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_ext.h > data/bindings/headers/fpdf_ext.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_flatten.h > data/bindings/headers/fpdf_flatten.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_formfill.h > data/bindings/headers/fpdf_formfill.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_fwlevent.h > data/bindings/headers/fpdf_fwlevent.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_javascript.h > data/bindings/headers/fpdf_javascript.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_ppo.h > data/bindings/headers/fpdf_ppo.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_progressive.h > data/bindings/headers/fpdf_progressive.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_save.h > data/bindings/headers/fpdf_save.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_searchex.h > data/bindings/headers/fpdf_searchex.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_signature.h > data/bindings/headers/fpdf_signature.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_structtree.h > data/bindings/headers/fpdf_structtree.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_sysfontinfo.h > data/bindings/headers/fpdf_sysfontinfo.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_text.h > data/bindings/headers/fpdf_text.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_thumbnail.h > data/bindings/headers/fpdf_thumbnail.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdf_transformpage.h > data/bindings/headers/fpdf_transformpage.h
  bsdtar -xOf "${srcdir}/pdfium-linux-x64-${_pdfiumver}.tgz" include/fpdfview.h > data/bindings/headers/fpdfview.h
  printf '%s\n' '{"major":149,"minor":0,"build":7825,"patch":0,"n_commits":0,"hash":null,"origin":"pdfium-binaries","flags":[]}' > data/linux_x64/version.json
  printf '%s\n' '{"version":7825,"flags":[],"windows_cross":false}' > data/bindings/version.json
}

build() {
  local _site_packages
  _site_packages="$(python -c 'import site; print(site.getsitepackages()[0])')"
  rm -rf "${srcdir}/ctypesgen-build"

  cd ctypesgen
  python -m build --wheel --no-isolation
  python -m installer --destdir="${srcdir}/ctypesgen-build" dist/*.whl

  cd "${srcdir}/${_name}-${pkgver}"
  PATH="${srcdir}/ctypesgen-build/usr/bin:${PATH}" \
    PYTHONPATH="${srcdir}/ctypesgen-build${_site_packages}${PYTHONPATH:+:${PYTHONPATH}}" \
    python -m build --wheel --no-isolation
}

package() {
  cd "${_name}-${pkgver}"
  python -m installer --destdir="${pkgdir}" dist/*.whl

  install -Dm644 LICENSES/Apache-2.0.txt "${pkgdir}/usr/share/licenses/${pkgname}/Apache-2.0.txt"
  install -Dm644 LICENSES/BSD-3-Clause.txt "${pkgdir}/usr/share/licenses/${pkgname}/BSD-3-Clause.txt"
  install -Dm644 LICENSES/CC-BY-4.0.txt "${pkgdir}/usr/share/licenses/${pkgname}/CC-BY-4.0.txt"
}
