[
  {
    "dir": "coverup-pdf",
    "latest": {
      "type": "github-tags",
      "repo": "digidigital/CoverUP"
    },
    "apply": {
      "type": "simple-tarball",
      "source_sha256_index": 0,
      "url": "https://github.com/digidigital/CoverUP/archive/refs/tags/{tag}.tar.gz"
    },
    "aur_extra_files": ["coverup.desktop"]
  },
  {
    "dir": "jottr",
    "latest": {
      "type": "github-tags",
      "repo": "mfat/jottr"
    },
    "apply": {
      "type": "simple-tarball",
      "source_sha256_index": 0,
      "url": "https://github.com/mfat/jottr/archive/refs/tags/{tag}.tar.gz"
    }
  },
  {
    "dir": "jottr-bin",
    "latest": {
      "type": "github-tags",
      "repo": "mfat/jottr"
    },
    "apply": {
      "type": "simple-tarball",
      "source_sha256_index": 0,
      "url": "https://github.com/mfat/jottr/releases/download/{tag}/jottr_{version}-1_all.deb"
    }
  }
]
